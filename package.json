{
  "name": "virtual-care-coordinator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1 --port 3099",
    "build": "next build",
    "start": "next start",
    "start:local": "next start --hostname 127.0.0.1 --port 3099",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "js-yaml": "4.1.0",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.13.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "autoprefixer": "10.4.20",
    "postcss": "8.5.6",
    "prisma": "^6.18.0",
    "tailwindcss": "3.4.16",
    "tsx": "^4.21.0",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
